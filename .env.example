# Shared app config
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_RAZORPAY_KEY_ID=

# Optional hard override for every environment
# REACT_APP_API_URL=https://your-backend.example.com/api

# Optional runtime environment override: development | qa | production
# REACT_APP_RUNTIME_ENV=qa

# Environment-specific API base URLs
REACT_APP_API_URL_DEV=http://api.dev.littleknownplanet.com/api
REACT_APP_API_URL_QA=http://api.qa.littleknownplanet.com/api
REACT_APP_API_URL_PROD=http://api.littleknownplanet.com/api

# Optional separate orders API
# REACT_APP_ORDERS_API_URL=https://your-orders-backend.example.com/api
